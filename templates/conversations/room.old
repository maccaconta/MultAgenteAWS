{% extends "base.html" %}
{% load static %}
{% block title %}Sala de simulação | Treinamento de Propagandistas{% endblock %}

{% block session_drawer %}
<div class="field">
  <div class="help" style="margin-top:0;">A configuração desta sessão já foi iniciada. Use a conversa ao centro para treinar abordagem, objeções e follow-ups.</div>
</div>
{% endblock %}

{% block content %}
<section class="hero room-hero">
  <span class="pill">Sessão #{{ session.id }}</span>
  <h2>Treinamento em andamento</h2>
  <p>Use a área central para conversar com o médico simulado e acompanhe à direita a trilha operacional dos agentes.</p>
</section>

<style>
  .room-hero {
    max-width: 980px;
    margin: 0 auto 18px;
  }

  .room-hero p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--muted);
    line-height: 1.6;
  }

  .session-hero-card {
    display: grid;
    grid-template-columns: repeat(4, minmax(0,1fr));
    gap: 16px;
    margin-top: 18px;
    padding: 18px 20px;
    background: linear-gradient(180deg, rgba(14, 22, 48, .82), rgba(9, 16, 34, .90));
    border: 1px solid rgba(124, 77, 255, .14);
    border-radius: 22px;
    box-shadow: var(--shadow-md);
  }

  .session-hero-kicker {
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .session-hero-value {
    font-size: 16px;
    font-weight: 700;
    color: #f3f6ff;
  }

  .hero-meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 18px;
    margin-top: 14px;
    flex-wrap: wrap;
  }

  .hero-copy-wrap {
    flex: 1 1 420px;
  }

  .hero-agents-inline {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex: 1 1 360px;
  }

  .hero-agent-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 999px;
    border: 1px solid rgba(124, 77, 255, .16);
    background: rgba(255,255,255,.04);
    font-size: 12px;
    font-weight: 700;
  }

  .chat-card {
    min-height: 72vh;
    display: flex;
    flex-direction: column;
  }

  .chat-card .chat-stream {
    flex: 1;
    overflow: auto;
    padding-right: 8px;
  }

  .chat-welcome {
    background: linear-gradient(180deg, rgba(99,179,255,.10), rgba(124,77,255,.08));
    border: 1px solid rgba(124,77,255,.18);
    padding: 18px 20px !important;
    min-height: auto !important;
  }

  .chat-welcome .welcome-title {
    display: block;
    margin-bottom: 10px;
    font-weight: 800;
    color: var(--text);
  }

  .chat-welcome .welcome-copy {
    display: block;
    line-height: 1.65;
  }

  .chat-welcome .welcome-examples {
    margin-top: 12px;
    color: var(--muted);
  }

  .chat-welcome .welcome-examples span {
    display: inline-block;
    margin-top: 8px;
    margin-right: 8px;
    padding: 8px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(124,77,255,.12);
    font-size: 12px;
  }

  .panel-title-row {
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    margin-bottom:14px;
  }

  .panel-title-row h3,.panel-title-row h4 { margin:0; }
  .panel-kicker {
    color:var(--muted);
    font-size:12px;
    letter-spacing:.08em;
    text-transform:uppercase;
    font-weight:700;
  }

  .timeline-panel {
    position: sticky;
    top: 108px;
    padding: 18px;
    background: linear-gradient(180deg, rgba(10,18,34,.94), rgba(8,14,29,.96));
    border-color: rgba(124,77,255,.16);
    max-height: min(78vh,900px);
    overflow:auto;
  }

  .timeline-intro {
    margin:0 0 14px;
    color:var(--muted);
    line-height:1.5;
    font-size:13px;
  }

  .timeline-feed {
    display:grid;
    gap:12px;
  }

  .timeline-item {
    position:relative;
    padding:12px 12px 12px 16px;
    border-radius:16px;
    border:1px solid rgba(255,255,255,.06);
    background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.025));
    overflow:hidden;
  }

  .timeline-item.done { border-color:rgba(99,179,255,.22); }
  .timeline-item.error { border-color:rgba(232,107,122,.28); }
  .timeline-item.running { border-color:rgba(124,77,255,.26); }

  .timeline-item-head {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    margin-bottom:8px;
  }

  .timeline-agent {
    display:inline-flex;
    align-items:center;
    gap:8px;
    min-width:0;
  }

  .timeline-agent-badge {
    width:28px;
    height:28px;
    border-radius:10px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    font-size:14px;
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.08);
    flex:0 0 auto;
  }

  .timeline-agent-label {
    font-size:13px;
    font-weight:800;
  }

  .timeline-item-title {
    font-size:12px;
    color:var(--muted);
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:.05em;
  }

  .timeline-item-message {
    font-size:12px;
    color:var(--muted);
    line-height:1.55;
  }

  .timeline-item-time {
    margin-top:8px;
    color:var(--muted-2);
    font-size:11px;
  }

  .timeline-empty {
    padding:14px;
    border-radius:16px;
    border:1px dashed rgba(255,255,255,.12);
    color:var(--muted);
    font-size:13px;
    line-height:1.5;
  }

  .evaluation-trace-box {
    margin-top:14px;
    padding:12px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.03);
  }

  .evaluation-trace-box h4 {
    margin:0 0 8px;
    font-size:12px;
    text-transform:uppercase;
    letter-spacing:.05em;
    color:var(--muted);
  }

  .evaluation-trace-box pre {
    margin:0;
    white-space:pre-wrap;
    word-break:break-word;
    font-size:12px;
    line-height:1.5;
    color:var(--text);
  }

  @media (max-width:1180px) {
    .timeline-panel { position:static; max-height:none; }
  }

  @media (max-width:980px) {
    .session-hero-card { grid-template-columns:1fr 1fr; }
    .hero-agents-inline { justify-content:flex-start; }
  }
</style>

<section class="room-layout">
  <aside class="grid">
    <div class="card" id="evaluation-panel">
      <div class="panel-title-row"><div><div class="panel-kicker">Monitoramento</div><h3>Avaliação corrente</h3></div></div>
      <div class="score" id="score-global">--</div>
      <div class="muted" style="margin-bottom:10px;">score global da conversa</div>
      <div id="dimensions"></div>
      <div style="margin-top:16px;"><strong>Forças</strong><div class="help" id="strengths">Sem avaliação ainda.</div></div>
      <div style="margin-top:16px;"><strong>Melhorias</strong><div class="help" id="improvements">Sem avaliação ainda.</div></div>
      <div class="evaluation-trace-box" id="evaluation-current-box" style="display:none;"><h4>Monitoramento Avaliação corrente</h4><pre id="evaluation-current-payload"></pre></div>
    </div>
  </aside>

  <div class="card chat-card">
    <div class="chat-stream" id="chat-stream">
      {% for turn in session.turns.all %}
      <div class="bubble {% if turn.role == 'user' %}user{% else %}assistant{% endif %}">
        <div class="message-meta">{{ turn.speaker_name|default:turn.get_role_display }} · {{ turn.created_at }}</div>
        {{ turn.content }}
      </div>
      {% empty %}
      <div class="bubble assistant chat-welcome">
        <div class="message-meta">Sistema</div>
        <span class="welcome-title">Treinamento iniciado. Use este espaço para praticar abordagem com médicos reais.</span>
        <span class="welcome-copy">Você pode treinar de três formas: 1) pedir orientação de como abordar uma especialidade ou tema; 2) pedir simulação de objeções e respostas; 3) fazer perguntas factuais quando precisar validar um dado documental da base.</span>
        <div class="welcome-examples">
          <span>Como abordar um médico sobre TDAH?</span>
          <span>Simule uma objeção sobre adesão ao tratamento</span>
          <span>Consulte na base para que serve Somalgin Cardio</span>
        </div>
      </div>
      {% endfor %}
    </div>
    <form class="composer" id="composer-form" method="post" action="">
      {% csrf_token %}
      <textarea id="message-input" name="message" placeholder="Digite a sua abordagem, objeção-resposta ou follow-up clínico."></textarea>
      <button id="send-button" type="submit">Enviar</button>
    </form>
  </div>

  <aside class="card timeline-panel" id="timeline-panel" data-agents-panel>
    <div class="panel-kicker">Pipeline do turno</div>
    <h3 style="margin:4px 0 8px;">Linha do tempo operacional</h3>
    <p class="timeline-intro">Cada etapa exibida abaixo inclui o agente responsável. A visão privilegia eventos que o backend confirmou, sem simular processamento infinito.</p>
    <div class="timeline-feed" id="timeline-feed">
      <div class="timeline-empty">Nenhum evento deste turno ainda. Quando você enviar a próxima mensagem, a linha do tempo mostrará cada etapa confirmada pela aplicação.</div>
    </div>
  </aside>
</section>
{% endblock %}

{% block extra_head %}
<link rel="stylesheet" href="{% static 'conversations/agent_panel_thinking.css' %}">
<script src="{% static 'conversations/agent_panel_thinking.js' %}"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  window.scrollTo(0, 0);
});
</script>
{% endblock %}
