DJANGO_SECRET_KEY=dev-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_KB_ID=
BEDROCK_AGENT_ROLE_ARN=

BEDROCK_TURN_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_EVALUATE_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_SUMMARIZE_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_SUPERVISOR_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_TIMEOUT_SECONDS=20
BEDROCK_AGENT_IDLE_SESSION_TTL=900
BEDROCK_ENABLE_TRACE=true
BEDROCK_STREAM_FINAL_RESPONSE=false
BEDROCK_AGENT_TEAM_MANIFEST=var/bedrock_agent_team_manifest.json

DEFAULT_TOP_K=3
DEFAULT_SCORE_THRESHOLD=0.1
DEFAULT_MAX_OUTPUT_TOKENS=768
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.9

CHANNEL_LAYER_BACKEND=channels.layers.InMemoryChannelLayer
REDIS_URL=redis://127.0.0.1:6379/1
